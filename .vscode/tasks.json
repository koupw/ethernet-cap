{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-Debug",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c11",
                "-Wall",
                "-Wextra",
                "-Wpedantic",
                "-I${workspaceFolder}/src",
                "-o",
                "${workspaceFolder}/build/${fileBasenameNoExtension}.exe",
                "${workspaceFolder}/src/*.c",
                "-lws2_32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "clear": true,
                "focus": true,
                "panel": "shared"
            },
            "detail": "编译当前文件到build目录"
        },
        {
            "label": "build-c++",
            "type": "shell",
            "command": "g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-I${fileDirname}",
                "-Wall",
                "-Wextra",
                "-Wpedantic",
                "-o",
                "${fileDirname}/build/${fileBasenameNoExtension}.exe",
                "${fileDirname}/*.cpp"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "clear": true,
                "focus": true,
                "panel": "shared"
            },
            "detail": "编译当前项目的所有C++文件到build目录"
        },
        {
            "label": "build-c",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-std=c11",
                "-g",
                "-Wall",
                "-Wextra",
                "-I${workspaceFolder}/src",
                "-o",
                "${workspaceFolder}/build/ethernet-cap.exe",
                "${workspaceFolder}/src/*.c",
                "-lws2_32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "clear": true,
                "focus": true,
                "panel": "shared"
            },
            "detail": "编译以太网上位机项目所有C文件"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "C:\\Software\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/build/${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ]
}